#!/usr/bin/env -S nix shell nixpkgs#python3 nixpkgs#ffmpeg --command python3
"""probe-quality — derive a media quality tag from a file via ffprobe.

Prints, one line per FILE (in argument order):  RES SOURCE VCODEC [10bit] [HDR] AUDIO CH
e.g.  1080p BluRay x265 TrueHD 5.1

- RES/VCODEC/bit-depth/HDR/AUDIO are read from the container (factual).
- SOURCE is a heuristic: lossless audio (TrueHD/DTS/FLAC/PCM) ⇒ BluRay, else WEB-DL.
  Override with --source; the file can't actually tell you BluRay vs WEB.
- Release GROUP is never in the file; append it yourself or pass --group.

Usage:  probe-quality [--source SRC] [--group GRP] FILE...
"""
import argparse
import subprocess
import sys

VCODEC = {"hevc": "x265", "h264": "x264", "av1": "AV1", "vp9": "VP9", "mpeg2video": "MPEG2"}
ACODEC = {"truehd": "TrueHD", "dts": "DTS", "eac3": "EAC3", "ac3": "AC3", "aac": "AAC",
          "flac": "FLAC", "opus": "Opus", "vorbis": "Vorbis", "mp3": "MP3", "pcm_s16le": "PCM"}
CH = {"1": "1.0", "2": "2.0", "3": "2.1", "6": "5.1", "7": "6.1", "8": "7.1"}
LOSSLESS = {"truehd", "dts", "flac", "mlp", "pcm_s16le", "pcm_s24le"}  # ⇒ likely BluRay


def fields(path, stream, entries):
    out = subprocess.run(
        ["ffprobe", "-v", "error", "-select_streams", stream,
         "-show_entries", f"stream={entries}", "-of", "default=noprint_wrappers=1", path],
        capture_output=True, text=True).stdout
    d = {}
    for line in out.splitlines():
        if "=" in line:
            k, v = line.split("=", 1)
            d[k] = v
    return d


def tag(path, source=None, group=None):
    v = fields(path, "v:0", "codec_name,height,pix_fmt,color_transfer")
    a = fields(path, "a:0", "codec_name,channels")
    parts = []
    if v.get("height"):
        parts.append(f"{v['height']}p")
    if source:
        parts.append(source)
    else:
        parts.append("BluRay" if a.get("codec_name") in LOSSLESS else "WEB-DL")
    parts.append(VCODEC.get(v.get("codec_name"), v.get("codec_name", "?")))
    if "10" in (v.get("pix_fmt") or ""):
        parts.append("10bit")
    if v.get("color_transfer") in ("smpte2084", "arib-std-b67"):
        parts.append("HDR")
    if a.get("codec_name"):
        parts.append(ACODEC.get(a["codec_name"], a["codec_name"]))
    if a.get("channels"):
        parts.append(CH.get(a["channels"], a["channels"]))
    if group:
        parts.append(group)
    return " ".join(parts)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--source")
    ap.add_argument("--group")
    ap.add_argument("files", nargs="+")
    args = ap.parse_args()
    for f in args.files:
        print(tag(f, args.source, args.group))


if __name__ == "__main__":
    main()
