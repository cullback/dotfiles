#!/usr/bin/env -S nix shell nixpkgs#python3 --command python3
"""tidy-show — normalize a show's folder + season *structure* to the convention.

Given a messy show folder it will:
  - rename the folder to `Name (year)` (stripping release cruft after the year)
  - move loose episode files (those with SxxExx) into `Season NN/` (zero-padded, season from SxxExx)
  - zero-pad existing `Season N` subfolders → `Season NN`
  - leave `Specials` and recognized extras folders (featurettes, behind the scenes, trailers, …) alone

It does NOT rename episode files — they must already match
`Name (year) - SxxExx - Title (quality).ext`. Anything it can't classify is reported, not touched.
Run medialint afterward to confirm. Default is a dry-run; pass --apply to perform changes.

Usage: tidy-show [--name "Name (year)"] [--apply] FOLDER
"""
import argparse
import os
import re
import sys

EXTRAS = {"behind the scenes", "deleted scenes", "featurettes", "interviews", "scenes",
          "samples", "shorts", "clips", "trailers", "theme-music", "extras", "specials"}
VIDEO = (".mkv", ".mp4")


def derive_name(folder):
    base = os.path.basename(folder.rstrip("/"))
    m = re.match(r"^(.+? \(\d{4}\))", base)
    return m.group(1) if m else None


def season_of(filename):
    m = re.search(r"\bS(\d{2})E\d{2,}", filename)
    return int(m.group(1)) if m else None


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--name", help="target 'Name (year)' (else derived from folder)")
    ap.add_argument("--apply", action="store_true", help="perform changes (default: dry-run)")
    ap.add_argument("folder")
    args = ap.parse_args()

    folder = args.folder.rstrip("/")
    if not os.path.isdir(folder):
        sys.exit(f"tidy-show: not a directory: {folder}")
    name = args.name or derive_name(folder)
    if not name:
        sys.exit(f"tidy-show: can't derive 'Name (year)' from {os.path.basename(folder)!r} — pass --name")

    parent = os.path.dirname(folder) or "."
    target = os.path.join(parent, name)
    plan = []            # (action, src, dst)
    unhandled = []
    for child in sorted(os.listdir(folder)):
        path = os.path.join(folder, child)
        low = child.lower()
        if os.path.isdir(path):
            sm = re.match(r"Season (\d+)$", child)
            if sm:
                padded = f"Season {int(sm.group(1)):02d}"
                if padded != child:
                    plan.append(("pad-season", child, padded))
            elif low in EXTRAS:
                pass  # leave extras / specials as-is
            else:
                unhandled.append(f"dir: {child}")
        elif child.lower().endswith(VIDEO):
            s = season_of(child)
            if s is None:
                unhandled.append(f"file (no SxxExx): {child}")
            else:
                plan.append(("to-season", child, f"Season {s:02d}/{child}"))
        # sidecars (.srt/.nfo/.jpg/etc.) ride along with their dir; ignore loose ones silently

    print(f"folder: {os.path.basename(folder)!r}\n     →: {name!r}")
    for action, src, dst in plan:
        print(f"  [{action}] {src}  →  {dst}")
    for u in unhandled:
        print(f"  [UNHANDLED] {u}")
    if not args.apply:
        print(f"\nDRY-RUN ({len(plan)} ops, {len(unhandled)} unhandled). Re-run with --apply.")
        return

    # apply: rename folder first, then operate inside target
    if target != folder:
        if os.path.exists(target):
            sys.exit(f"tidy-show: target already exists: {target}")
        os.rename(folder, target)
    for action, src, dst in plan:
        s = os.path.join(target, src)
        d = os.path.join(target, dst)
        os.makedirs(os.path.dirname(d), exist_ok=True)
        os.rename(s, d)
    # prune any now-empty dirs left behind
    for root, dirs, files in os.walk(target, topdown=False):
        if root != target and not os.listdir(root):
            os.rmdir(root)
    print(f"\nAPPLIED: {len(plan)} ops.")


if __name__ == "__main__":
    main()
