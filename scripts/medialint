#!/usr/bin/env -S nix shell nixpkgs#python3 --command python3
"""medialint — check that filenames obey naming conventions.

Rules live in a TOML file at the root being checked (default: current dir):

    # .medialint.toml  — use '' literal strings so regexes need no escaping
    ignore = [ '(.*/)?\\.DS_Store' ]          # files matching are skipped
    allow  = [ 'films/[^/]+ \\(\\d{4}\\)/.+\\.(mkv|mp4)' ]   # must match one

Each file's path (relative to the root, '/'-separated) must fullmatch at least one
`allow` regex, unless it matches an `ignore` regex. Anything else is a violation.

Usage:  medialint [PATH]      (PATH defaults to the current directory)
Exit:   0 ok · 1 violations · 2 usage/config error
"""
import argparse
import os
import re
import sys
import tomllib

CONFIG_NAME = ".medialint.toml"


def die(msg):
    sys.exit(f"medialint: {msg}")


def compile_all(patterns, key, cfg):
    out = []
    for i, pat in enumerate(patterns):
        if not isinstance(pat, str):
            die(f"{cfg}: {key}[{i}] is not a string")
        try:
            out.append(re.compile(pat))
        except re.error as e:
            die(f"{cfg}: {key}[{i}] invalid regex {pat!r}: {e}")
    return out


def load_rules(cfg):
    try:
        with open(cfg, "rb") as f:
            data = tomllib.load(f)
    except (OSError, tomllib.TOMLDecodeError) as e:
        die(f"cannot read {cfg}: {e}")
    allow = compile_all(data.get("allow", []), "allow", cfg)
    ignore = compile_all(data.get("ignore", []), "ignore", cfg)
    if not allow:
        die(f"{cfg}: no `allow` rules — every file would fail")
    return allow, ignore


def lint(root, allow, ignore):
    ok, violations = 0, []
    for dirpath, _dirs, files in os.walk(root):
        for name in files:
            rel = os.path.relpath(os.path.join(dirpath, name), root)
            if rel == CONFIG_NAME:
                continue
            if any(r.fullmatch(rel) for r in ignore):
                continue
            if any(r.fullmatch(rel) for r in allow):
                ok += 1
            else:
                violations.append(rel)
    return ok, sorted(violations)


def main():
    ap = argparse.ArgumentParser(description="Lint filenames against a regex allowlist.")
    ap.add_argument("path", nargs="?", default=".", help="root to check (default: cwd)")
    ap.add_argument("-q", "--quiet", action="store_true", help="print only violations")
    args = ap.parse_args()

    root = os.path.abspath(args.path)
    if not os.path.isdir(root):
        die(f"not a directory: {root}")
    cfg = os.path.join(root, CONFIG_NAME)
    if not os.path.isfile(cfg):
        die(f"no {CONFIG_NAME} in {root}")

    allow, ignore = load_rules(cfg)
    ok, violations = lint(root, allow, ignore)
    total = ok + len(violations)

    for v in violations:
        print(f"  ✗ {v}")
    if violations:
        print(f"\n{len(violations)} violation(s) · {ok}/{total} ok", file=sys.stderr)
        sys.exit(1)
    if not args.quiet:
        print(f"✓ all {ok} files match conventions")


if __name__ == "__main__":
    main()
